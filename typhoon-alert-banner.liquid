{% comment %}
  Typhoon Alert Banner Section
  Add this to your theme sections or include it in your header
{% endcomment %}

<div class="typhoon-alert-banner bg-red-600 text-white py-4 px-4 md:px-6 relative z-50">
  <div class="container mx-auto">
    <div class="flex items-center justify-between gap-4 flex-wrap md:flex-nowrap">
      <div class="flex items-start gap-3 flex-1">
        <svg class="w-6 h-6 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
        </svg>
        <div class="flex-1">
          <h3 class="font-bold text-lg mb-1">⚠️ TYPHOON TINO ALERT - Eastern Visayas</h3>
          <p class="text-sm md:text-base">
            <strong>Typhoon Tino</strong> is expected to make landfall early morning tomorrow. 
            Orders and deliveries may experience significant delays. Please stay safe and monitor local weather updates.
          </p>
          <p class="text-xs md:text-sm mt-2 opacity-90">
            🏠 Stay indoors • 📦 Shipments suspended until further notice • ☎️ Contact us for order concerns
          </p>
        </div>
      </div>
      <button onclick="this.closest('.typhoon-alert-banner').style.display='none'" 
              class="text-white hover:text-gray-200 transition-colors flex-shrink-0 p-1">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
.typhoon-alert-banner {
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  animation: slideDown 0.3s ease-out;
}

@keyframes slideDown {
  from {
    transform: translateY(-100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@media (max-width: 768px) {
  .typhoon-alert-banner h3 {
    font-size: 1rem;
  }
}
</style>



